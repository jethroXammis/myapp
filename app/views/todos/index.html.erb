<h1 class="text-3xl font-bold mb-6">Todos</h1>
<%= link_to 'New Todo', new_todo_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6" %>
<table class="min-w-full bg-white shadow rounded-lg">
  <thead>
    <tr>
      <th class="px-6 py-3 text-left text-xl">Title</th>
      <th class="px-6 py-3 text-left text-xl">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @todos.each do |todo| %>
      <tr class="hover:bg-gray-50 odd:bg-blue-50 even:bg-white">
        <td class="px-6 py-4"><%= render todo %></td>
        <td class="px-6 py-4">
          <%= link_to 'Show', todo, class: "text-blue-600 hover:underline mr-2" %>
          <%= link_to 'Edit', edit_todo_path(todo), class: "text-yellow-600 hover:underline mr-2" %>
          <%= link_to 'Destroy', todo, method: :delete, data: { confirm: 'Are you sure?' }, class: "text-red-600 hover:underline" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

