<h1 class="text-3xl font-bold mb-6">Projects</h1>
<%= link_to 'New Project', new_project_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6" %>
<table class="min-w-full bg-white shadow rounded-lg">
  <thead>
    <tr>
      <th class="px-6 py-3 text-left text-xl">Name</th>
      <th class="px-6 py-3 text-left text-xl">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @projects.each do |project| %>
      <tr class="hover:bg-gray-50 odd:bg-blue-50 even:bg-white">
        <td class="px-6 py-4"><%= project.name %></td>
        <td class="px-6 py-4">
          <%= link_to 'Show', project, class: "text-blue-600 hover:underline mr-2" %>
          <%= link_to 'Edit', edit_project_path(project), class: "text-yellow-600 hover:underline mr-2" %>
          <%= link_to 'Destroy', project, method: :delete, data: { confirm: 'Are you sure?' }, class: "text-red-600 hover:underline" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>


