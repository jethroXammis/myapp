<h1><%= @project.name %></h1>
<ul>
<% @project.todos.each do |todo|%>
  <li>
    <%= link_to todo.name, todo_path(todo), class: "text-blue-600" %>
    <% if todo.completed %> ✓ <% end %>
  </li>
<% end %>
</ul>

<%= button_to "Delete Project", project_path(@project), method: :delete, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6" %>