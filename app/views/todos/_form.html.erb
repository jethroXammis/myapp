<%= form_with(model: todo) do |form| %>
  <% if todo.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(todo.errors.count, "error") %> prohibited this todo from being saved:</h2>

      <ul>
        <% todo.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %> 
  
  <div class="flex flex-col gap-2">
    <%= form.label :name, class: "text-left text-xl font-bold" %>
    <%= form.text_field :name, class: "border border-gray-300 rounded-md p-2 shadow-sm text-gray-900 text-sm rounded-lg block p-2.5" %>

    <%= form.label :description, class: "text-left text-xl font-bold" %>
    <%= form.text_field :description, class: "border border-gray-300 rounded-md p-2 shadow-sm text-gray-900 text-sm rounded-lg block p-2.5" %>

    <%= form.label :completed, class: "text-left text-xl font-bold" %>
    <%= form.checkbox :completed %>

    <%= form.label :priority, class: "text-left text-xl font-bold" %>
    <%= form.number_field :priority, class: "border border-gray-300 rounded-md p-2 shadow-sm text-gray-900 text-sm rounded-lg block p-2.5" %>

    <%= form.label :project_id, class: "text-left text-xl font-bold" %>
    <%= form.collection_select :project_id, Project.all, :id, :name, prompt: "Select a project", class: "border border-gray-300 rounded-md p-2 shadow-sm text-gray-900 text-sm rounded-lg block p-2.5" %>
 
    <%= form.submit "Submit", class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6"  %>
  </div>
<% end %>
