<p style="color: green"><%= notice %></p>

<%= render @todo %>

<div>
  <%= link_to "Edit this todo", edit_todo_path(@todo), class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6" %>
  
  <%= link_to "Back to todos", todos_path, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6" %>

  <%= button_to "Destroy this todo", @todo, method: :delete, class: "inline-block bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 mb-6" %>
</div>
